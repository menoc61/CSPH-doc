{
  "$schema": "https://opencode.ai/config.json",
  "username": "ciph-project",
  "instructions": ["AGENTS.md", "CONTEXT.md"],
  "skills": {
    "paths": [".opencode/skills", ".agents/skills"]
  },
  "mcp": {
    "eraser": {
      "type": "http",
      "url": "https://app.eraser.io/api/mcp",
      "enabled": true,
      "description": "Eraser.io diagram-as-code (cloud, K8s, network, security)"
    }
  },
  "permission": {
    "edit": "allow",
    "bash": {
      "npm *": "allow",
      "node *": "allow",
      "bun *": "allow",
      "git *": "allow",
      "pytest *": "allow",
      "python *": "allow",
      "npx *": "allow",
      "markdownlint *": "allow",
      "lychee *": "allow",
      "mmdc *": "allow",
      "*": "ask"
    },
    "external_directory": {
      "~/*": "allow"
    }
  },
  "logLevel": "INFO",
  "share": "manual",
  "autoupdate": true,
  "snapshot": true
}
